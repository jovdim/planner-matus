# Environment Variables Template
# Skopíruj tento súbor ako .env a dopíš svoje hodnoty
# .env je v .gitignore, nebude sa commitovať

# === Google Analytics 4 ===
# ID získaš na https://analytics.google.com
# POZOR: Aj tak musíš aktualizovať public/index.html (2 miesta)
# Toto je len pre budúce rozšírenie
REACT_APP_GA4_ID=G-XXXXXXXXXX

# === Public URL (len ak nasadzuješ na iný subdomain/path) ===
# Default je /planovac/ z package.json > homepage
# REACT_APP_PUBLIC_URL=/planovac/
